<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YemekTarifi.KategoriAnaSayfa"
             Title="Yemek Tarifleri"
             BackgroundColor="#F2D5C4">

    <AbsoluteLayout>
        <Button
 x:Name="btnGeriDon"
 Text="Geri Dön"
 Clicked="GeriDon"
 BackgroundColor="#D9CD25"
 TextColor="Black"
 CornerRadius="12"
 Padding="10"
 Margin="10"
 HorizontalOptions="Start"/>

        <!-- Menü butonu sağ üstte -->
        <Button x:Name="MenuButton"
                Text="☰"
                WidthRequest="40"
                HeightRequest="40"
                BackgroundColor="Transparent"
                TextColor="#4D5947"
                Clicked="MenuButton_Clicked"
                AbsoluteLayout.LayoutBounds="1,0,40,40"
                AbsoluteLayout.LayoutFlags="PositionProportional" />

        <!-- Ana içerik -->
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All"
                    Margin="0,80,0,0">
            <StackLayout Padding="10" Spacing="15">

                <!-- Başlık -->
                <Label Text="Yemek Kategorileri"
                       FontSize="26"
                       HorizontalOptions="Center"
                       TextColor="#4D5947"
                       FontAttributes="Bold"
                       Margin="0,5" />

                <!-- Günün Yemeği -->
                <Frame x:Name="GununYemegiLayout"
                       BorderColor="#BBBF4E"
                       BackgroundColor="#FFF5E5"
                       CornerRadius="15"
                       Padding="5"
                       HasShadow="True">
                    <StackLayout Spacing="5">
                        <Label Text="Günün Yemeği"
                               FontSize="22"
                               TextColor="#A67063"
                               HorizontalOptions="Center"
                               FontAttributes="Bold" />

                        <Image x:Name="gununYemegiImage"
                               HeightRequest="350"
                               WidthRequest="500"
                               Aspect="AspectFill"
                               Margin="0,5"
                               BackgroundColor="#eee">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Tapped="GununYemegi_Tapped" />
                            </Image.GestureRecognizers>
                        </Image>

                        <Label x:Name="GununYemegiLabel"
                               Text="..."
                               FontSize="20"
                               HeightRequest="80"
                               WidthRequest="80"
                               TextColor="#4D5947"
                               HorizontalOptions="Center"
                               FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="GununYemegi_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </StackLayout>
                </Frame>

                <!-- Arama Kutusu -->
                <SearchBar x:Name="yemekAramaBar"
                           Placeholder="Yemek ismi yazın..."
                           SearchButtonPressed="YemekAramaBar_SearchButtonPressed"
                           BackgroundColor="#FFF5E5"
                           TextColor="Black"
                           PlaceholderColor="#8B8C69"
                           FontSize="16" />
                <!-- Kategori Listesi -->
                <CollectionView x:Name="kategoriListView"
                SelectionMode="Single"
                SelectionChanged="KategoriSecildi">

                    <!-- 4 Sütunlu Grid Görünüm -->
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="4" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BorderColor="#BBBF4E"
                                   CornerRadius="10"
                                   Margin="5"
                                   Padding="10"
                                   BackgroundColor="#FFE6CC"
                                   HasShadow="True"
                                   HeightRequest="80"
                                   WidthRequest="160"
                                   HorizontalOptions="Center">
                                <Label Text="{Binding Ad}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#4D5947"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </StackLayout>
        </ScrollView>


        <!-- Menü en sona taşındı, diğer her şeyin üstünde görünür -->
        <CollectionView x:Name="MenuCollectionView"
                        IsVisible="False"
                        SelectionMode="Single"
                        SelectionChanged="MenuCollectionView_SelectionChanged"
                        BackgroundColor="#4D5947"
                        WidthRequest="160"
                        HeightRequest="220"
                        AbsoluteLayout.LayoutBounds="1,0.1,160,220"
                        AbsoluteLayout.LayoutFlags="PositionProportional">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10"
                           Margin="5"
                           CornerRadius="5"
                           BackgroundColor="#8B8C69"
                           HasShadow="True">
                        <Label Text="{Binding}"
                               FontSize="12"
                               TextColor="White" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </AbsoluteLayout>


</ContentPage>