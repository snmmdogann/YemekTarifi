        Title="Kategoriler"
        ContentTemplate="{DataTemplate local:KategoriAnaSayfa}"
        Route="KategoriAnaSayfa" />

    <ShellContent
        Title="Tarifler"
        ContentTemplate="{DataTemplate local:KategoriDetaySayfasi}"
        Route="KategoriDetaySayfasi" />

    <ShellContent
        Title="Tarifler"
        ContentTemplate="{DataTemplate local:TariflerSayfasi}"
