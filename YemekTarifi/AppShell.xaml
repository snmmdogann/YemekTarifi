         Route="TarifEklemeSayfasi" />

    <ShellContent
        Title="tarifEkleme"
        ContentTemplate="{DataTemplate local:YorumlarimSayfasi}"
        Route="YorumlarimSayfasi" />

    <ShellContent
        Title="Puan güncelleme"
        ContentTemplate="{DataTemplate local:PuanGuncellemeSayfasi}"
