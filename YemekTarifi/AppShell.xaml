    <ShellContent
    Title="Tarifler"
    ContentTemplate="{DataTemplate local:TarifGuncellemeSayfasi}"
    Route="TarifGuncellemeSayfasi" />
  

    <ShellContent
        Title="Şifre Değiştir"
        ContentTemplate="{DataTemplate local:SifreDegistirSayfasi}"
        Route="SifreDegistirSayfasi" />

   

    <ShellContent
        Title="Favoriler"
        ContentTemplate="{DataTemplate local:FavorilerSayfasi}"
        Route="favoriler sayfası"
/>
    <ShellContent
         Title="arifEkleme"
