<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YemekTarifi.SifreDegistirSayfasi"
             Title="Şifre Değiştir"
             BackgroundColor="#F2D5C4">

    <StackLayout Padding="20" VerticalOptions="CenterAndExpand" Spacing="15" HorizontalOptions="Center" >

        <Label Text="Eski Şifre"
               TextColor="black"
               HorizontalOptions="Center" />

        <Entry x:Name="EskiSifreEntry"
               IsPassword="True"
               Placeholder="Eski şifrenizi girin"
               TextColor="black"
               PlaceholderColor="#8B8C69"
               HorizontalOptions="Center"
               WidthRequest="250" />

        <Label Text="Yeni Şifre"
               TextColor="black"
               HorizontalOptions="Center" />

        <Entry x:Name="YeniSifreEntry"
               IsPassword="True"
               Placeholder="Yeni şifrenizi girin"
               TextColor="black"
               PlaceholderColor="#8B8C69"
               HorizontalOptions="Center"
               WidthRequest="250" />

        <Label Text="Yeni Şifre Tekrar"
               TextColor="black"
               HorizontalOptions="Center" />

        <Entry x:Name="YeniSifreTekrarEntry"
               IsPassword="True"
               Placeholder="Yeni şifreyi tekrar girin"
               TextColor="black"
               PlaceholderColor="#8B8C69"
               HorizontalOptions="Center"
               WidthRequest="250" />

        <Button Text="Şifreyi Değiştir"
                BackgroundColor="#BBBF4E"
                TextColor="#A67063"
                HorizontalOptions="Center"
                WidthRequest="150"
                Clicked="SifreDegistirButton_Clicked" />
    </StackLayout>
</ContentPage>