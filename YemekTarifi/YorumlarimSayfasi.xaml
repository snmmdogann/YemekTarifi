<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YemekTarifi.YorumlarimSayfasi"
             Title="Yorumlarım"
             BackgroundColor="#F2D5C4">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Button
x:Name="btnGeriDon"
Text="Geri Dön"
Clicked="GeriDon"
BackgroundColor="#D9CD25"
TextColor="Black"
CornerRadius="12"
Padding="10"
Margin="10"
HorizontalOptions="Start"/>

            <Label Text="Yorumlarım" 
                   FontSize="36" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="Black" />

            <CollectionView x:Name="YorumlarCollectionView"
                            Margin="0,10,0,0"
                            ItemsLayout="VerticalGrid, 3"
                            ItemSizingStrategy="MeasureAllItems"
                            SelectionMode="None"
                            HorizontalScrollBarVisibility="Never"
                            VerticalScrollBarVisibility="Always">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#BBBF4E"
                               BorderColor="#8B8C69"
                               Padding="15"
                               Margin="12,50,12,50" 
                            CornerRadius="15"
                               HasShadow="True"
                               WidthRequest="350"
                               HeightRequest="470">


                            <VerticalStackLayout Spacing="8">

                                <Label Text="Yorum" 
                                       FontSize="24" 
                                       FontAttributes="Bold" 
                                       TextColor="Black"/>

                                <Label Text="{Binding Yorum}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       LineBreakMode="WordWrap"
                                       MaxLines="7"/>

                                <Label Text="Puan" 
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       Margin="0,10,0,0" 
                                       TextColor="Black" />

                                <Label Text="{Binding Deger}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"
                                       TextColor="Black" />

                                <Label Text="Tarif Adı" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="Black" 
                                       Margin="0,10,0,0" />

                                <Label Text="{Binding TarifAdi}" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />

                                <Label Text="Eklenme Tarihi" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="Black" 
                                       Margin="0,10,0,0" />

                                <Label Text="{Binding EklenmeTarihi, StringFormat='{0:dd.MM.yyyy}'}" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="Black" />

                                <Label Text="Güncellenme Tarihi" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="Black" 
                                       Margin="0,10,0,0" />

                                <Label Text="{Binding GuncellenmeTarihi, StringFormat='{0:dd.MM.yyyy}'}" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="Black" />

                                <HorizontalStackLayout Margin="0,15,0,0" Spacing="25" HorizontalOptions="Center">

                                    <Button Text="Sil" 
                                            BackgroundColor="#A67063" 
                                            TextColor="White" 
                                            CommandParameter="{Binding}" 
                                            Clicked="SilPuan_Clicked" 
                                            CornerRadius="15"
                                            WidthRequest="140"  
                                        HeightRequest="50"
                                       
                                        FontSize="20"
                                            FontAttributes="Bold"/>

                                    <Button Text="Güncelle" 
                                            BackgroundColor="#4D5947" 
                                            TextColor="White" 
                                            CommandParameter="{Binding}" 
                                            Clicked="GuncellePuan_Clicked" 
                                            CornerRadius="15"
                                            WidthRequest="140" 
                                            HeightRequest="50"
                                            
                                            FontSize="20"
                                            FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>