<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YemekTarifi.TarifEklemeSayfasi"
             Title="Tarif Ekle"
             BackgroundColor="#F2D5C4">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15" HorizontalOptions="Center" WidthRequest="320">


            <Button
        x:Name="btnGeriDon"
    Text="Geri Dön"
    Clicked="GeriDon"
    BackgroundColor="#BBBF4E"
    TextColor="#4D5947"
    CornerRadius="12"
    Padding="10"
    Margin="10"
    HorizontalOptions="Start"/>
            

            <Entry x:Name="adEntry"
                   Placeholder="Tarif Adı"
                   TextColor="#000000"
                   FontSize="20"
                   PlaceholderColor="#BBBF4E"
                   HorizontalOptions="FillAndExpand"
                   BackgroundColor="#8B8C69"
                   Margin="0,0,0,5"
                   />

            <Editor x:Name="malzemeEntry"
                    Placeholder="Malzemeler"
                    AutoSize="TextChanges"
                    TextColor="#000000"
                    FontSize="20"
                    PlaceholderColor="#BBBF4E"
                    HeightRequest="100"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="#8B8C69"
                    Margin="0,0,0,5"
                    />

            <Editor x:Name="yapilisEditor"
                    Placeholder="Yapılışı"
                    AutoSize="TextChanges"
                    TextColor="#000000"
                    FontSize="20"
                    PlaceholderColor="#BBBF4E"
                    HeightRequest="150"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="#8B8C69"
                    Margin="0,0,0,5"
                    />

            <Entry x:Name="pisirmeSuresiEntry"
                   Placeholder="Pişirme Süresi (dakika)"
                   Keyboard="Numeric"
                   TextColor="#000000"
                   FontSize="20"
                   PlaceholderColor="#BBBF4E"
                   HorizontalOptions="FillAndExpand"
                   BackgroundColor="#8B8C69"
                   Margin="0,0,0,10"
                   />

            <Picker x:Name="kategoriPicker"
                    Title="Kategori Seçin"
                    TextColor="#000000"
                    FontSize="20"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="#8B8C69"
                    Margin="0,0,0,10"
                    />

            <Image x:Name="resimGoruntuleme"
                   WidthRequest="200"
                   HeightRequest="200"
                   HorizontalOptions="Center"
                   Margin="0,10" />

            <Button Text="Resim Seç"
                    Clicked="ResimSecButon_Clicked"
                    BackgroundColor="#4D5947"
                    TextColor="White"
                    FontSize="22"
                    HorizontalOptions="Center"
                    WidthRequest="180"
                    Margin="0,0,0,10" />

            <Button Text="Tarifi Kaydet"
                    Clicked="EkleButon_Clicked"
                    BackgroundColor="#A67063"
                    TextColor="White"
                    FontSize="22"
                    HorizontalOptions="Center"
                    WidthRequest="180" />

        </StackLayout>
    </ScrollView>

</ContentPage>